{
  "compilerOptions": {
    "composite": true,
    "outDir": "node_modules/.cache/tsc-node",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "types": ["node"],
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["electron", "vite.config.ts", "vitest.config.ts", "package.json"],
  "exclude": [
    "electron/main/services/__tests__/i18n.usage.test.ts",
    "electron/main/services/__tests__/ui.promptViewer.usage.test.ts"
  ]
}
