{
  "name": "electron-vite-react",
  "version": "2.13.0",
  "private": true,
  "description": "A AI novel writer application",
  "license": "MIT",
  "author": "LizardLiang <shotup0101@gmail.com>",
  "type": "module",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "release": "vite build && electron-builder --publish never",
    "release:win": "vite build && electron-builder --win --publish never",
    "release:mac": "vite build && electron-builder --mac --publish never",
    "release:dir": "vite build && electron-builder --dir --publish never",
    "preview": "vite preview",
    "pretest": "vite build --mode=test",
    "test": "vitest run",
    "test:e2e": "pnpm pretest && playwright test",
    "typecheck": "tsc -b",
    "typecheck:src": "tsc --noEmit"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "js-tiktoken": "^1.0.21",
    "openai": "^6.42.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7",
    "sql.js": "^1.14.1",
    "uuid": "^14.0.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^43.0.0",
    "electron-builder": "^26.8.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-electron": "^1.0.1",
    "vite-plugin-electron-renderer": "^1.0.0",
    "vitest": "^4.1.8"
  }
}
